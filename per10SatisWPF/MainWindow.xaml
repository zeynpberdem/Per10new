<Window x:Class="per10SatisWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Per10 Satış Sistemi"
        Height="750" Width="1300"
        MinHeight="600" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ÜST BAR -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource AccentBlue}" CornerRadius="6"
                            Width="34" Height="34" Margin="0,0,10,0">
                        <TextBlock Text="P" FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Per10 Satış" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextWhite}" VerticalAlignment="Center"/>
                    <Border Background="#1E2D4A" CornerRadius="4" Margin="12,0,0,0" Padding="8,3">
                        <TextBlock Text="Test Mağaza" FontSize="11" Foreground="{StaticResource AccentBlue}"/>
                    </Border>
                </StackPanel>

                <!-- Barkod Alanı -->
                <Border Grid.Column="1" Background="{StaticResource BgCard}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                        MaxWidth="400" VerticalAlignment="Center" Margin="20,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Background="{StaticResource AccentBlue}"
                                CornerRadius="0,8,8,0" Padding="12,0">
                            <TextBlock Text="📷" FontSize="15" VerticalAlignment="Center"/>
                        </Border>
                        <TextBox x:Name="txtBarkod" Background="Transparent"
                                 Foreground="{StaticResource TextWhite}" BorderThickness="0"
                                 Padding="12,9" FontSize="13" CaretBrush="White"
                                 KeyDown="txtBarkod_KeyDown"
                                 GotFocus="Placeholder_GotFocus"
                                 LostFocus="Placeholder_LostFocus"
                                 Tag="Barkod okut veya yaz..."/>
                    </DockPanel>
                </Border>

                <!-- Sağ Butonlar -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="↩ Son Satışı İptal"
                            Background="Transparent" Foreground="{StaticResource AccentRed}"
                            FontSize="12" BorderThickness="0" Cursor="Hand"
                            Click="btnSatisgeri_Click" Margin="0,0,12,0"/>
                    <Button Content="⚙" Background="Transparent"
                            Foreground="{StaticResource TextGray}"
                            FontSize="22" BorderThickness="0" Cursor="Hand"
                            Click="btnAyarlar_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ANA İÇERİK -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="175"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- SOL: KATEGORİLER -->
            <Border Grid.Column="0" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                <DockPanel Margin="8">

                    <!-- Arama Kutusu -->
                    <Border DockPanel.Dock="Top" Background="{StaticResource BgCard}" CornerRadius="8"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,10,0,10">
                        <TextBox x:Name="txtArama" Background="Transparent"
                                 Foreground="{StaticResource TextWhite}" BorderThickness="0"
                                 Padding="10,8" FontSize="12" CaretBrush="White"
                                 TextChanged="txtArama_TextChanged"
                                 GotFocus="Placeholder_GotFocus"
                                 LostFocus="Placeholder_LostFocus"
                                 Tag="Ürün ara..."/>
                    </Border>

                    <TextBlock DockPanel.Dock="Top" Text="KATEGORİLER"
                               Foreground="{StaticResource TextGray}"
                               FontSize="10" FontWeight="Bold" Margin="4,0,0,8"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="pnlKategoriler"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ORTA: ÜRÜNLER -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="pnlUrunler" Margin="10"/>
            </ScrollViewer>

            <!-- SAĞ: SEPET + ÖDEME -->
            <Border Grid.Column="2" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Sepet Başlığı -->
                    <Grid Grid.Row="0" Margin="14,12,14,8">
                        <TextBlock Text="Sepet" Foreground="{StaticResource TextWhite}"
                                   FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="Temizle" HorizontalAlignment="Right"
                                Background="Transparent" Foreground="{StaticResource AccentRed}"
                                FontSize="12" BorderThickness="0" Cursor="Hand"
                                Click="btnSepetTemizle_Click"/>
                    </Grid>

                    <!-- Sepet Ürünleri -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="8,0">
                        <StackPanel x:Name="pnlSepet"/>
                    </ScrollViewer>

                    <!-- Toplam -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,1,0,1" Padding="14,10">
                        <Grid>
                            <TextBlock Text="Toplam Tutar" Foreground="{StaticResource TextGray}"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblToplam" Text="0,00 ₺"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource TextWhite}"
                                       FontSize="24" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <!-- Numpad Gösterge -->
                    <Border Grid.Row="3" Background="{StaticResource BgCard}" CornerRadius="8"
                            Margin="8,6,8,0" Padding="12,8">
                        <Grid>
                            <TextBlock Text="İndirim / Miktar" Foreground="{StaticResource TextGray}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="lblNumpad" Text=""
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource AccentBlue}"
                                       FontSize="16" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <!-- Numpad -->
                    <Grid Grid.Row="4" Margin="8,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="44"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Content="7" Style="{StaticResource NumpadStyle}" Click="Numpad_Click"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="8" Style="{StaticResource NumpadStyle}" Click="Numpad_Click"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="9" Style="{StaticResource NumpadStyle}" Click="Numpad_Click"/>
                        <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource NumpadStyle}" Click="Numpad_Click"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource NumpadStyle}" Click="Numpad_Click"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource NumpadStyle}" Click="Numpad_Click"/>
                        <Button Grid.Row="2" Grid.Column="0" Content="1" Style="{StaticResource NumpadStyle}" Click="Numpad_Click"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="2" Style="{StaticResource NumpadStyle}" Click="Numpad_Click"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="3" Style="{StaticResource NumpadStyle}" Click="Numpad_Click"/>
                        <Button Grid.Row="3" Grid.Column="0" Content="." Style="{StaticResource NumpadStyle}" Click="Numpad_Click"/>
                        <Button Grid.Row="3" Grid.Column="1" Content="0" Style="{StaticResource NumpadStyle}" Click="Numpad_Click"/>
                        <Button Grid.Row="3" Grid.Column="2" Content="C"
                                Background="{StaticResource AccentRed}"
                                Style="{StaticResource NumpadStyle}" Click="NumpadC_Click"/>
                    </Grid>

                    <!-- Ödeme Butonları -->
                    <StackPanel Grid.Row="5" Margin="8,2,8,10">
                        <Button Content="💵   Nakit Ödeme   (F1)" Height="46" Margin="0,0,0,6"
                                Background="{StaticResource AccentGreen}" Foreground="White"
                                FontSize="14" FontWeight="Bold"
                                Template="{StaticResource RoundBtnTemplate}"
                                Cursor="Hand" Click="btnNakit_Click"/>
                        <Button Content="💳   Kredi Kartı   (F4)" Height="46"
                                Background="{StaticResource AccentBlue}" Foreground="White"
                                FontSize="14" FontWeight="Bold"
                                Template="{StaticResource RoundBtnTemplate}"
                                Cursor="Hand" Click="btnKredi_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
